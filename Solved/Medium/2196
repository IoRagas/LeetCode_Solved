/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
 /*
    Simple Tree Construction 
    1. Keep account of parents for each node
    2. Use Unordered_map for efficient retrievals
 */
class Solution {
public:
    TreeNode* createBinaryTree(vector<vector<int>>& descriptions) {
        TreeNode* ans = nullptr;
        unordered_map<int, int> depth;
        unordered_map<int, TreeNode*> table; //Parent
        set<int> tt;
        for(auto &v : descriptions){
            int x = v[0], y= v[1];
            if(table[x] == nullptr){
                table[x] = new TreeNode(x);
            }
             if(table[y] == nullptr){
                table[y] = new TreeNode(y);
            }
            TreeNode* parent = table[x];
            TreeNode* child = table[y];
            if(v[2] == 1){
                parent->left = child;
            }else
            {
                parent->right = child;
            }
            depth[y] += 1;
            tt.insert(x);
            tt.insert(y);
        }
        int q = 1e5;
        for(auto &v : tt)
        {
            if(depth[v] == 0)
            {
                ans = table[v];
                break;
            }
        }
        return ans;
    }
};
