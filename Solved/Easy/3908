class Solution {
public:
    bool validDigit(int n, int x) {
        if(n == 0 && x == 0) return false;
        bool valid = false;
        while(n > 0)
        {
            if(n / 10 == 0 && n % 10 == x) return false;
            if(n % 10 == x) valid = true;
            n = n / 10;
        }

        return valid;
    }
};
